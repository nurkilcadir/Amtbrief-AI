# ─────────────────────────────────────────────────────────────
# AmtBrief AI — STANDALONE mobile app env (NOT the SuperApp MiniApp)
# Copy to .env.local (dev) or set in your standalone deployment.
# In the SuperApp deployment, DO NOT set STANDALONE_AUTH — the MiniApp
# keeps using Silent SSO and none of this applies.
# ─────────────────────────────────────────────────────────────

# Turns on the standalone login screen (Google / Apple / email) and makes the
# middleware redirect unauthenticated users to /login instead of SuperApp SSO.
STANDALONE_AUTH=1

# Public URL of THIS standalone deployment. OAuth redirect URIs are built from
# it, so it must match exactly what you register with Google/Apple.
# Dev example: http://localhost:4173
APP_URL=https://your-standalone-domain.example

# Secret used to sign the user_session cookie (any long random string).
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# ── Google Sign-In ───────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (type: Web application). Authorized redirect URI:
#   <APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sign in with Apple ───────────────────────────────────────
# Apple Developer → Certificates, Identifiers & Profiles
#   APPLE_CLIENT_ID   = your Services ID (e.g. ai.amtbrief.app.web)
#   APPLE_TEAM_ID     = your 10-char Team ID
#   APPLE_KEY_ID      = the Key ID of the Sign in with Apple .p8 key
#   APPLE_PRIVATE_KEY = contents of the .p8 file (\n-escaped is fine)
# Return URL to register: <APP_URL>/api/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
